# Copy this file to `.env.local` (already gitignored) and fill in the values.

# --- Supabase (dashboard → Project Settings → API) --------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Cloudinary (dashboard → Settings → Upload → "Add unsigned preset") -----
# The preset MUST be set to "Unsigned" in Cloudinary for browser uploads.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# --- Backblaze B2 (server-side only — set as Supabase secrets, NOT here) ----
# These are consumed by the `get-b2-upload-url` Edge Function:
#   supabase secrets set B2_KEY_ID=... B2_APPLICATION_KEY=... \
#     B2_BUCKET_ID=... B2_BUCKET_NAME=... \
#     B2_PUBLIC_BASE_URL=https://video.yourdomain.com \
#     B2_FILE_PREFIX=videos/
